rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /boards/{boardId} {
      allow read, write: if request.auth != null;
      match /objects/{objectId} {
        allow read, write: if request.auth != null;
      }
    }
    // Allow listing boards for the dashboard
    match /boards/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
