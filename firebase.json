{
  "firestore": {
    "database": "(default)",
    "location": "us-central1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "codebase": "default",
      "source": "./functions",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "./node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
//        "echo \"${RESOURCE_DIR}\"",
//        "cd \"$RESOURCE_DIR\" && npx eslint --ext .js,.ts .",
//        "npm --prefix functions run lint",
//        "npm --prefix \"${RESOURCE_DIR}\" run build"
      ]
    }
  ]
}
